<Window x:Class="PusulaNotifier.NotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PusulaNotifier"
        Width="360" SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize">

  <Window.Resources>
    <!-- Slide-in animasyonu -->
    <Storyboard x:Key="SlideIn">
      <DoubleAnimation Storyboard.TargetName="Root"
                       Storyboard.TargetProperty="Opacity"
                       From="0" To="1" Duration="0:0:0.25"/>
      <ThicknessAnimation Storyboard.TargetName="Root"
                          Storyboard.TargetProperty="Margin"
                          From="0,20,0,-20" To="0,0,0,0"
                          Duration="0:0:0.25">
        <ThicknessAnimation.EasingFunction>
          <CubicEase EasingMode="EaseOut"/>
        </ThicknessAnimation.EasingFunction>
      </ThicknessAnimation>
    </Storyboard>
    <Storyboard x:Key="SlideOut">
      <DoubleAnimation Storyboard.TargetName="Root"
                       Storyboard.TargetProperty="Opacity"
                       From="1" To="0" Duration="0:0:0.2"/>
      <ThicknessAnimation Storyboard.TargetName="Root"
                          Storyboard.TargetProperty="Margin"
                          From="0,0,0,0" To="0,10,0,-10"
                          Duration="0:0:0.2"/>
    </Storyboard>
  </Window.Resources>

  <!-- Dış gölge -->
  <Border x:Name="Root" Margin="12" Opacity="0">
    <Border.Effect>
      <DropShadowEffect BlurRadius="20" ShadowDepth="4"
                        Color="#000000" Opacity="0.15" Direction="270"/>
    </Border.Effect>

    <Border Background="White" CornerRadius="10"
            BorderBrush="#E5E7EB" BorderThickness="1">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>  <!-- Header -->
          <RowDefinition Height="Auto"/>  <!-- Body -->
          <RowDefinition Height="Auto"/>  <!-- Progress -->
          <RowDefinition Height="Auto"/>  <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- Sol renk aksanı -->
        <Border x:Name="AccentBar" Grid.RowSpan="4"
                Width="4" HorizontalAlignment="Left"
                Background="#3B82F6" CornerRadius="10,0,0,10"/>

        <!-- ── Header ── -->
        <Grid Grid.Row="0" Margin="16,14,14,8">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>

          <!-- Tip ikonu -->
          <Border x:Name="IconBg" Grid.Column="0"
                  Width="28" Height="28" CornerRadius="6"
                  Background="#EFF6FF" Margin="0,0,10,0">
            <TextBlock x:Name="IconText" Text="ℹ"
                       FontSize="13" HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
          </Border>

          <!-- Başlık -->
          <StackPanel Grid.Column="1" VerticalAlignment="Center">
            <TextBlock x:Name="TitleText"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="#111111" TextWrapping="Wrap"/>
            <TextBlock x:Name="FromText"
                       FontSize="10" Foreground="#9CA3AF" Margin="0,1,0,0"/>
          </StackPanel>

          <!-- Kapat -->
          <Button Grid.Column="2" Click="CloseBtn_Click"
                  Width="24" Height="24"
                  Background="Transparent" BorderThickness="0"
                  Cursor="Hand" VerticalAlignment="Top">
            <Button.Template>
              <ControlTemplate TargetType="Button">
                <Border Background="{TemplateBinding Background}" CornerRadius="4"
                        Padding="4">
                  <TextBlock Text="✕" FontSize="10" Foreground="#9CA3AF"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <ControlTemplate.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F3F4F6"/>
                  </Trigger>
                </ControlTemplate.Triggers>
              </ControlTemplate>
            </Button.Template>
          </Button>
        </Grid>

        <!-- ── Mesaj gövdesi ── -->
        <Border Grid.Row="1" Margin="16,0,14,0"
                Background="#F9FAFB" CornerRadius="6"
                Padding="10,8">
          <TextBlock x:Name="BodyText"
                     FontSize="11" Foreground="#374151"
                     TextWrapping="Wrap" LineHeight="17"/>
        </Border>

        <!-- ── Otomatik kapanma progress ── -->
        <Grid Grid.Row="2" Margin="16,10,14,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <Border Background="#F3F4F6" CornerRadius="2" Height="3" VerticalAlignment="Center">
            <Border x:Name="ProgressBar" HorizontalAlignment="Left"
                    Background="#D1D5DB" CornerRadius="2" Height="3" Width="0"/>
          </Border>
          <TextBlock x:Name="TimerText" Grid.Column="1"
                     FontSize="10" Foreground="#9CA3AF"
                     Margin="8,0,0,0" VerticalAlignment="Center"/>
        </Grid>

        <!-- ── Footer: butonlar + zaman ── -->
        <Grid Grid.Row="3" Margin="16,10,14,14">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>

          <TextBlock x:Name="SentAtText" Grid.Column="0"
                     FontSize="10" Foreground="#9CA3AF"
                     VerticalAlignment="Center"/>

          <Button x:Name="SnoozeBtn" Grid.Column="1"
                  Content="Ertele (10 dk)" Style="{StaticResource BtnOutline}"
                  Click="SnoozeBtn_Click" Padding="10,0"/>

          <Button x:Name="OkBtn" Grid.Column="3"
                  Content="Tamam" Style="{StaticResource BtnPrimary}"
                  Click="OkBtn_Click" Padding="16,0"/>
        </Grid>

      </Grid>
    </Border>
  </Border>
</Window>
