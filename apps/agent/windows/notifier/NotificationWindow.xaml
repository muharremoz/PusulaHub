<Window x:Class="PusulaNotifier.NotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PusulaHub — Yeni Mesaj"
        Width="480" SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

  <Window.Resources>
    <Storyboard x:Key="FadeIn">
      <DoubleAnimation Storyboard.TargetName="Root"
                       Storyboard.TargetProperty="Opacity"
                       From="0" To="1" Duration="0:0:0.2"/>
      <DoubleAnimation Storyboard.TargetName="Root"
                       Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                       From="0.96" To="1" Duration="0:0:0.2">
        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
      </DoubleAnimation>
      <DoubleAnimation Storyboard.TargetName="Root"
                       Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                       From="0.96" To="1" Duration="0:0:0.2">
        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
      </DoubleAnimation>
    </Storyboard>
    <Storyboard x:Key="FadeOut">
      <DoubleAnimation Storyboard.TargetName="Root"
                       Storyboard.TargetProperty="Opacity"
                       From="1" To="0" Duration="0:0:0.15"/>
    </Storyboard>
  </Window.Resources>

  <!-- Dim overlay — tüm ekranı karartmaz, pencere arkasında gölge efekti -->
  <Border x:Name="Root" Margin="20" Opacity="0">
    <Border.RenderTransform>
      <ScaleTransform ScaleX="1" ScaleY="1" CenterX="240" CenterY="0"/>
    </Border.RenderTransform>
    <Border.Effect>
      <DropShadowEffect BlurRadius="32" ShadowDepth="8" Color="#000000" Opacity="0.18" Direction="270"/>
    </Border.Effect>

    <Border Background="White" CornerRadius="12" ClipToBounds="True">

      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/> <!-- Üst renk şeridi + başlık -->
          <RowDefinition Height="Auto"/> <!-- Gönderen bilgisi -->
          <RowDefinition Height="Auto"/> <!-- Mesaj gövdesi -->
          <RowDefinition Height="Auto"/> <!-- Eylem butonları -->
        </Grid.RowDefinitions>

        <!-- ══ Üst başlık bandı ══ -->
        <Border x:Name="HeaderBand" Grid.Row="0" CornerRadius="12,12,0,0" Padding="20,16">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- İkon -->
            <Border x:Name="IconContainer" Grid.Column="0"
                    Width="36" Height="36" CornerRadius="8"
                    Margin="0,0,12,0" VerticalAlignment="Center">
              <TextBlock x:Name="IconGlyph" FontSize="18"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <!-- Başlık + tip badge -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
              <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <Border x:Name="TypeBadge" CornerRadius="4" Padding="6,2">
                  <TextBlock x:Name="TypeLabel" FontSize="9" FontWeight="Bold"/>
                </Border>
              </StackPanel>
              <TextBlock x:Name="TitleText"
                         FontSize="14" FontWeight="Bold"
                         Foreground="#111111" TextWrapping="Wrap"/>
            </StackPanel>
          </Grid>
        </Border>

        <!-- ══ Alıcı bilgisi ══ -->
        <Border Grid.Row="1" Background="#FAFAFA"
                BorderBrush="#F0F0F0" BorderThickness="0,1,0,1"
                Padding="20,10">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Grid.Column="0">
              <!-- Avatar -->
              <Border Width="28" Height="28" CornerRadius="14"
                      Background="#E5E7EB" Margin="0,0,10,0">
                <TextBlock x:Name="AvatarLetter" FontSize="11" FontWeight="Bold"
                           Foreground="#374151"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <StackPanel VerticalAlignment="Center">
                <!-- "Sayın [Kullanıcı Adı]" -->
                <TextBlock x:Name="FromText" FontSize="12" FontWeight="SemiBold" Foreground="#111111"/>
                <!-- Bağlı olduğu firma -->
                <TextBlock x:Name="ToCompanyText" FontSize="10" Foreground="#6B7280"/>
              </StackPanel>
            </StackPanel>
            <TextBlock x:Name="SentAtText" Grid.Column="1"
                       FontSize="10" Foreground="#9CA3AF" VerticalAlignment="Center"/>
          </Grid>
        </Border>

        <!-- ══ Mesaj gövdesi ══ -->
        <Border Grid.Row="2" Padding="20,16">
          <TextBlock x:Name="BodyText"
                     FontSize="12" Foreground="#374151"
                     TextWrapping="Wrap" LineHeight="20"/>
        </Border>

        <!-- ══ Eylem alanı ══ -->
        <Border Grid.Row="3" Background="#FAFAFA"
                BorderBrush="#F0F0F0" BorderThickness="0,1,0,0"
                CornerRadius="0,0,12,12" Padding="16,12">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Pusula Yazılım marka etiketi -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Opacity="0.55">
              <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="#374151" Text="Pusula Yazılım"/>
            </StackPanel>

            <!-- Okudum, Anladım -->
            <Button x:Name="OkBtn" Grid.Column="1"
                    Content="Okudum, Anladım"
                    Style="{StaticResource BtnPrimary}"
                    Click="OkBtn_Click" Padding="20,0"/>
          </Grid>
        </Border>

      </Grid>
    </Border>
  </Border>
</Window>
