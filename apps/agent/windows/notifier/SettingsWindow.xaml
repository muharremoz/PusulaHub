<Window x:Class="PusulaNotifier.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PusulaNotifier — Ayarlar"
        Width="400" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F4F2F0">

  <Window.Resources>
    <Style TargetType="TextBlock" x:Key="Label">
      <Setter Property="FontSize"   Value="11"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="#374151"/>
      <Setter Property="Margin"     Value="0,0,0,4"/>
    </Style>
    <Style TargetType="TextBox">
      <Setter Property="Height"          Value="32"/>
      <Setter Property="FontSize"        Value="11"/>
      <Setter Property="BorderBrush"     Value="#D1D5DB"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding"         Value="8,0"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
  </Window.Resources>

  <StackPanel Margin="16">

    <!-- Başlık -->
    <Border Background="White" CornerRadius="8" Padding="14,12" Margin="0,0,0,12">
      <Border.Effect>
        <DropShadowEffect BlurRadius="8" ShadowDepth="2" Color="#000" Opacity="0.06"/>
      </Border.Effect>
      <StackPanel>
        <TextBlock Text="BAĞLANTI" FontSize="10" FontWeight="SemiBold"
                   Foreground="#9CA3AF" Margin="0,0,0,10"
                   CharacterSpacing="60"/>
        <TextBlock Style="{StaticResource Label}" Text="Hub Adresi"/>
        <TextBox x:Name="TxtHub" Margin="0,0,0,10"/>
        <TextBlock Style="{StaticResource Label}" Text="Agent ID"/>
        <TextBox x:Name="TxtAgentId" IsReadOnly="True" Background="#F9FAFB" FontFamily="Consolas" FontSize="10"/>
        <TextBlock Style="{StaticResource Label}" Text="Token" Margin="0,10,0,4"/>
        <TextBox x:Name="TxtToken" IsReadOnly="True" Background="#F9FAFB" FontFamily="Consolas" FontSize="10"/>
      </StackPanel>
    </Border>

    <Border Background="White" CornerRadius="8" Padding="14,12" Margin="0,0,0,12">
      <Border.Effect>
        <DropShadowEffect BlurRadius="8" ShadowDepth="2" Color="#000" Opacity="0.06"/>
      </Border.Effect>
      <StackPanel>
        <TextBlock Text="ZAMANLAMA" FontSize="10" FontWeight="SemiBold"
                   Foreground="#9CA3AF" Margin="0,0,0,10" CharacterSpacing="60"/>
        <TextBlock Style="{StaticResource Label}" Text="Kontrol Aralığı (saniye)"/>
        <TextBox x:Name="TxtInterval" Width="80" HorizontalAlignment="Left"/>
      </StackPanel>
    </Border>

    <!-- Test bildirimi -->
    <Border Background="White" CornerRadius="8" Padding="14,12" Margin="0,0,0,12">
      <Border.Effect>
        <DropShadowEffect BlurRadius="8" ShadowDepth="2" Color="#000" Opacity="0.06"/>
      </Border.Effect>
      <StackPanel>
        <TextBlock Text="TEST" FontSize="10" FontWeight="SemiBold"
                   Foreground="#9CA3AF" Margin="0,0,0,10" CharacterSpacing="60"/>
        <Button Content="Test Bildirimi Göster" Style="{StaticResource BtnOutline}"
                HorizontalAlignment="Left" Click="TestBtn_Click"/>
      </StackPanel>
    </Border>

    <!-- Butonlar -->
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
      <Button Content="İptal" Style="{StaticResource BtnOutline}"
              Click="CancelBtn_Click" Margin="0,0,8,0"/>
      <Button Content="Kaydet" Style="{StaticResource BtnPrimary}"
              Click="SaveBtn_Click"/>
    </StackPanel>

  </StackPanel>
</Window>
