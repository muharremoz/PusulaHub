# PusulaHub — Ofis Sunucusu (10.10.10.5) Production Ortamı
# Bu dosyayı .env.production olarak kopyalayın ve "CHANGE_ME" yerlerini doldurun.
# .env.production git'e commit EDİLMEZ (.gitignore).

# ── Veritabanı (ofis sunucusu local SQL Server) ────────────────────────
DB_SERVER=localhost
DB_NAME=PusulaHub
DB_USER=SA
DB_PASSWORD=CHANGE_ME
DB_PORT=1433

# ── Firma API ──────────────────────────────────────────────────────────
FIRMA_API_URL=http://pars.pusulanet.net:50003/api
FIRMA_API_USERNAME=PusulaLisans
FIRMA_API_PASSWORD=14PuSuLaYaZ53**
FIRMA_API_TIMEOUT=10

# ── Agent ortak secret ─────────────────────────────────────────────────
AGENT_SECRET=psl-agent-2026-secret

# ── AES-256-GCM — DB'deki şifrelenmiş sunucu parolaları için ──────────
# PROD için üret: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# UYARI: Bir kez set edilip DB'ye şifreli veri yazıldıktan SONRA değiştirilmez.
ENCRYPTION_KEY=CHANGE_ME_BASE64_32_BYTE

# ── Auth / Session ─────────────────────────────────────────────────────
# Dev'dekinden FARKLI olmalı. Üret:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=CHANGE_ME_BASE64_32_BYTE
AUTH_TRUST_HOST=true
PUSULA_SESSION_SECRET=CHANGE_ME_BASE64_32_BYTE

# ── Module registry (Hub ↔ SpareFlow) ─────────────────────────────────
# Üç uygulamada da AYNI olmalı (Switch, Hub, SpareFlow)
INTERNAL_APP_KEY=CHANGE_ME_HEX_64

