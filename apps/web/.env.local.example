# PusulaHub Ortam Değişkenleri
# Bu dosyayı .env.local olarak kopyalayın ve doldurun

# Agent'ların kayıt olurken kullanacağı ortak secret
# Her agent'ın config.json dosyasındaki "secret" değeriyle eşleşmeli
AGENT_SECRET=pusulahub-secret-degistirin

# Sunucu şifrelerini (Windows + SQL SA) şifrelemek için AES-256-GCM master key.
# Üretmek için: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# UYARI: Bu anahtarı production'da değiştirme — mevcut DB'deki şifreler çözülemez hale gelir.
ENCRYPTION_KEY=degistirin-base64-32-byte-key

# API sunucusu (api.pusulanet.net) bant genişliği — /tv ekranı tile'ı.
# Token URL'de taşınır; Hub backend proxy'ler (tarayıcıya sızmaz).
BANDWIDTH_API_URL=http://api.pusulanet.net/app-heartbeat/bandwidth?token=DEGISTIRIN

# ── Birleşik platform / Supabase Auth (Faz 3) ──────────────────────────────
# Tek Supabase (CRM'inki genişletilmiş). Alt-domain SSO cookie'si + auth.users havuzu.
NEXT_PUBLIC_SUPABASE_URL=https://supabase.pusulanet.net
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key (GİZLİ, server-only, NEXT_PUBLIC OLMADAN). CRM'inkiyle AYNI.
# Session'sız sunucu bağlamları için: agent-poller + /api/agent/* + mesaj/şablon
# veri katmanı (RLS bypass). Kaynak: VPS new-supabase.env SUPABASE_SERVICE_ROLE_KEY.
SUPABASE_SERVICE_ROLE_KEY=

# Alt-domain SSO: cookie'yi tüm *.pusulanet.net app'leriyle paylaş.
# Prod: .pusulanet.net  ·  localhost'ta BOŞ bırak (host-only cookie).
NEXT_PUBLIC_COOKIE_DOMAIN=.pusulanet.net

# Switch (login + launcher) origin — oturumsuz/erişimsiz kullanıcı buraya döner.
# Prod: https://app.pusulanet.net  ·  boşsa same-origin fallback.
NEXT_PUBLIC_SWITCH_URL=https://app.pusulanet.net

# ── Hub SQL Server (mssql) — AppUsers köprüsü + domain verisi (Faz 4'e kadar) ──
DB_SERVER=10.10.10.5
DB_NAME=PusulaHub
DB_USER=SA
DB_PASSWORD=
DB_PORT=1433
